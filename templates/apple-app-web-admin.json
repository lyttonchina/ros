{
  "ROSTemplateFormatVersion": "2015-09-01",
  "Description": "Web Admin 前端静态资源部署：OSS + CDN + DNS",
  "Parameters": {
    "BucketName": {
      "Default": "web-admin-frontend-bucket-3",
      "Type": "String",
      "Description": "OSS 存储桶名称（全局唯一）"
    },
    "CdnDomainName": {
      "Default": "admin.apple-app.cn",
      "Type": "String",
      "Description": "CDN 加速域名（需为已备案域名）"
    },
    "SubDomainName": {
      "Default": "admin",
      "Type": "String",
      "Description": "子域名 / RR 记录"
    },
    "MainDomainName": {
      "Default": "apple-app.cn",
      "Type": "String",
      "Description": "主域名（需已在阿里云 DNS 中添加）"
    },
    "OssFrontendDir": {
      "Default": "dist/",
      "Type": "String",
      "Description": "前端静态文件在 OSS 中的目录路径"
    },
    "CertType": {
      "Default": "cas",
      "Type": "String",
      "Description": "证书类型：cas(阿里云证书服务)/free(免费证书)/upload(上传证书)",
      "AllowedValues": [
        "cas",
        "free",
        "upload"
      ]
    },
    "CertName": {
      "Default": "",
      "Type": "String",
      "Description": "证书名称（从阿里云证书服务获取，certType 为 cas 时必填）"
    },
    "ServerCertificate": {
      "Default": "",
      "Type": "String",
      "Description": "证书内容（PEM 格式，certType 为 cas 时留空）"
    },
    "PrivateKey": {
      "Default": "",
      "Type": "String",
      "Description": "私钥内容（PEM 格式，certType 为 cas 时留空）"
    }
  },
  "Resources": {
    "AutoEnableCDN": {
      "Type": "ALIYUN::ROS::AutoEnableService",
      "Properties": {
        "ServiceName": "CDN"
      }
    },
    "OssBucket": {
      "Type": "ALIYUN::OSS::Bucket",
      "Properties": {
        "BucketName": {
          "Ref": "BucketName"
        },
        "StorageClass": "Standard",
        "AccessControl": "private",
        "RedundancyType": "LRS"
      }
    },
    "CdnDomain": {
      "Type": "ALIYUN::CDN::Domain",
      "Properties": {
        "DomainName": {
          "Ref": "CdnDomainName"
        },
        "CdnType": "web",
        "Sources": {
          "Fn::Sub": [
            "[{\"content\":\"${content}\", \"type\":\"oss\", \"priority\":\"20\", \"port\":80}]",
            {
              "content": {
                "Fn::GetAtt": [
                  "OssBucket",
                  "DomainName"
                ]
              }
            }
          ]
        },
        "Scope": "domestic"
      },
      "DependsOn": [
        "OssBucket",
        "AutoEnableCDN"
      ]
    },
    "CdnDomainConfig": {
      "Type": "ALIYUN::CDN::DomainConfig",
      "Properties": {
        "DomainNames": {
          "Ref": "CdnDomainName"
        },
        "FunctionList": [
          {
            "FunctionName": "l2_oss_key",
            "FunctionArgs": [
              {
                "ArgName": "private_oss_auth",
                "ArgValue": "on"
              },
              {
                "ArgName": "private_oss_tbl",
                "ArgValue": ""
              }
            ]
          }
        ]
      },
      "DependsOn": [
        "CdnDomain"
      ]
    },
    "CdnHttpsConfig": {
      "Type": "ALIYUN::OOS::Execution",
      "Properties": {
        "TemplateName": "ACS-CDN-SetDomainServerCertificate",
        "Parameters": {
          "DomainName": {
            "Ref": "CdnDomainName"
          },
          "CertType": {
            "Ref": "CertType"
          },
          "CertName": {
            "Ref": "CertName"
          },
          "ServerCertificate": {
            "Ref": "ServerCertificate"
          },
          "PrivateKey": {
            "Ref": "PrivateKey"
          }
        }
      },
      "DependsOn": [
        "CdnDomainConfig"
      ]
    },
    "DnsRecord": {
      "Type": "ALIYUN::DNS::DomainRecord",
      "Properties": {
        "TTL": 600,
        "Type": "CNAME",
        "Value": {
          "Fn::GetAtt": [
            "CdnDomain",
            "Cname"
          ]
        },
        "RR": {
          "Ref": "SubDomainName"
        },
        "DomainName": {
          "Ref": "MainDomainName"
        }
      },
      "DependsOn": [
        "CdnDomain"
      ]
    }
  },
  "Outputs": {
    "OssBucketName": {
      "Description": "OSS 存储桶名称",
      "Value": {
        "Ref": "OssBucket"
      }
    },
    "OssBucketEndpoint": {
      "Description": "OSS 存储桶内网访问地址（用于回源配置）",
        "Value": {
          "Fn::GetAtt": [
            "OssBucket",
            "DomainName"
          ]
        }
    },
    "CdnDomainName": {
      "Description": "CDN 加速域名",
      "Value": {
        "Ref": "CdnDomainName"
      }
    },
    "CdnCname": {
      "Description": "CDN CNAME 值（需在 DNS 中配置）",
      "Value": {
        "Fn::GetAtt": [
          "CdnDomain",
          "Cname"
        ]
      }
    },
    "DnsRecordId": {
      "Description": "DNS 解析记录 ID",
      "Value": {
        "Ref": "DnsRecord"
      }
    },
    "WebsiteUrl": {
      "Description": "前端站点访问地址",
      "Value": {
        "Fn::Sub": "https://${SubDomainName}.${MainDomainName}"
      }
    }
  }
}
