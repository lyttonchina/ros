{
  "ROSTemplateFormatVersion": "2015-09-01",
  "Resources": {
    "AutoEnableCDN": {
      "Type": "ALIYUN::ROS::AutoEnableService",
      "Properties": {
        "ServiceName": "CDN"
      }
    },
    "OssBucket": {
      "Type": "ALIYUN::OSS::Bucket",
      "Properties": {
        "AccessControl": "public-read",
        "BlockPublicAccess": false,
        "StorageClass": "Standard",
        "BucketName": {
          "Ref": "BucketName"
        },
        "RedundancyType": "LRS",
        "WebsiteConfiguration": {
          "IndexDocument": "index.html",
          "ErrorDocument": "index.html"
        }
      }
    },
    "DnsRecord": {
      "Type": "ALIYUN::DNS::DomainRecord",
      "Properties": {
        "TTL": 600,
        "Type": "CNAME",
        "Value": {
          "Fn::GetAtt": [
            "CdnDomain",
            "Cname"
          ]
        },
        "RR": {
          "Ref": "SubDomainName"
        },
        "DomainName": {
          "Ref": "MainDomainName"
        }
      },
      "DependsOn": [
        "CdnDomain"
      ]
    },
    "CdnDomain": {
      "Type": "ALIYUN::CDN::Domain",
      "Properties": {
        "Sources": {
          "Fn::Sub": [
            "[{\"content\":\"${content}\", \"type\":\"oss\", \"priority\":\"20\", \"port\":80}]",
            {
              "content": {
                "Fn::Sub": "${BucketName}.oss-${ALIYUN::Region}.aliyuncs.com"
              }
            }
          ]
        },
        "DomainName": {
          "Ref": "CdnDomainName"
        },
        "CdnType": "web",
        "Scope": "domestic"
      },
      "DependsOn": [
        "OssBucket",
        "AutoEnableCDN"
      ]
    },
    "CdnHttpsConfig": {
      "Type": "ALIYUN::OOS::Execution",
      "Properties": {
        "Parameters": {
          "certId": {
            "Ref": "CertId"
          },
          "domainName": {
            "Ref": "CdnDomainName"
          },
          "certName": {
            "Ref": "CertName"
          },
          "privateKey": {
            "Ref": "PrivateKey"
          },
          "certType": {
            "Ref": "CertType"
          },
          "serverCertificate": {
            "Ref": "ServerCertificate"
          }
        },
        "TemplateName": "ACS-CDN-SetDomainServerCertificate"
      },
      "DependsOn": [
        "CdnDomain"
      ]
    }
  },
  "Description": "Web Admin 前端静态资源部署：OSS + CDN + DNS。支持 SPA 路由（所有 404 请求会 fallback 到 index.html）",
  "Parameters": {
    "CertId": {
      "Default": "24508261",
      "Type": "String",
      "Description": "证书 ID（从阿里云证书服务获取，certType 为 cas 时与 certName 二选一）"
    },
    "CdnDomainName": {
      "Default": "admin.apple-app.cn",
      "Type": "String",
      "Description": "CDN 加速域名（需为已备案域名）"
    },
    "SubDomainName": {
      "Default": "admin",
      "Type": "String",
      "Description": "子域名 / RR 记录"
    },
    "CertName": {
      "Default": "",
      "Type": "String",
      "Description": "证书名称（certType 为 cas 时与 certId 二选一）"
    },
    "OssFrontendDir": {
      "Default": "dist/",
      "Type": "String",
      "Description": "前端静态文件在 OSS 中的目录路径"
    },
    "CertType": {
      "Default": "cas",
      "Type": "String",
      "Description": "证书类型：cas(阿里云证书服务)/upload(上传证书)",
      "AllowedValues": [
        "cas",
        "upload"
      ]
    },
    "BucketName": {
      "Default": "web-admin-prod-guangzhou",
      "Type": "String",
      "Description": "OSS 存储桶名称（全局唯一）"
    },
    "MainDomainName": {
      "Default": "apple-app.cn",
      "Type": "String",
      "Description": "主域名（需已在阿里云 DNS 中添加）"
    },
    "PrivateKey": {
      "Default": "",
      "Type": "String",
      "Description": "私钥内容（PEM 格式，certType 为 cas 时留空）"
    },
    "ServerCertificate": {
      "Default": "",
      "Type": "String",
      "Description": "证书内容（PEM 格式，certType 为 cas 时留空）"
    }
  },
  "Outputs": {
    "OssBucketName": {
      "Description": "OSS 存储桶名称",
      "Value": {
        "Ref": "OssBucket"
      }
    },
    "CdnDomainName": {
      "Description": "CDN 加速域名",
      "Value": {
        "Ref": "CdnDomainName"
      }
    },
    "WebsiteUrl": {
      "Description": "前端站点访问地址",
      "Value": {
        "Fn::Sub": "https://${SubDomainName}.${MainDomainName}"
      }
    },
    "OssStaticWebsiteUrl": {
      "Description": "OSS 静态网站访问地址（用于验证 OSS 层 SPA fallback 配置）",
      "Value": {
        "Fn::Sub": "http://${BucketName}.oss-${ALIYUN::Region}.aliyuncs.com"
      }
    },
    "CdnCname": {
      "Description": "CDN CNAME 值（需在 DNS 中配置）",
      "Value": {
        "Fn::GetAtt": [
          "CdnDomain",
          "Cname"
        ]
      }
    },
    "DnsRecordId": {
      "Description": "DNS 解析记录 ID",
      "Value": {
        "Ref": "DnsRecord"
      }
    },
    "OssBucketEndpoint": {
      "Description": "OSS 存储桶静态网站访问地址（用于 CDN 回源）",
      "Value": {
        "Fn::Sub": "${ALIYUN::Region}.aliyuncs.com"
      }
    }
  }
}