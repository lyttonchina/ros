{
  "ROSTemplateFormatVersion": "2015-09-01",
  "Resources": {
    "SaeNamespace": {
      "Type": "ALIYUN::SAE::Namespace",
      "Properties": {
        "NamespaceName": {
          "Fn::Sub": "${ALIYUN::StackName}_namespace"
        },
        "NamespaceId": {
          "Fn::Sub": "${ALIYUN::Region}:${NamespaceId}"
        },
        "NamespaceDescription": "Namespace for SAE applications"
      }
    },
    "SecretDB_PASSWORD": {
      "Type": "ALIYUN::SAE::Secret",
      "Properties": {
        "NamespaceId": {
          "Fn::GetAtt": [
            "SaeNamespace",
            "NamespaceId"
          ]
        },
        "SecretName": {
          "Fn::Sub": "${AppName}-db-password"
        },
        "SecretType": "Opaque",
        "SecretData": {
          "DB_PASSWORD": "sample"
        }
      }
    },
    "SecretREDIS_PASSWORD": {
      "Type": "ALIYUN::SAE::Secret",
      "Properties": {
        "NamespaceId": {
          "Fn::GetAtt": [
            "SaeNamespace",
            "NamespaceId"
          ]
        },
        "SecretName": {
          "Fn::Sub": "${AppName}-redis-password"
        },
        "SecretType": "Opaque",
        "SecretData": {
          "REDIS_PASSWORD": "sample"
        }
      }
    },
    "SaeIngress": {
      "Type": "ALIYUN::SAE::Ingress",
      "Properties": {
        "CertIds": [
          {
            "Ref": "CertificateId"
          }
        ],
        "Description": {
          "Ref": "AppName"
        },
        "Rules": [
          {
            "Path": "/*",
            "Domain": {
              "Fn::Join": [
                ".",
                [
                  {
                    "Ref": "DomainPrefix"
                  },
                  {
                    "Ref": "RootDomain"
                  }
                ]
              ]
            },
            "BackendProtocol": "http",
            "ContainerPort": 8080,
            "AppId": {
              "Ref": "SaeApplication"
            }
          }
        ],
        "ListenerPort": 443,
        "DefaultRule": {
          "BackendProtocol": "http",
          "ContainerPort": 8080,
          "AppId": {
            "Ref": "SaeApplication"
          }
        },
        "ListenerProtocol": "HTTPS",
        "LoadBalanceType": "alb",
        "SlbId": {
          "Ref": "AlbInstance"
        },
        "NamespaceId": {
          "Fn::GetAtt": [
            "SaeNamespace",
            "NamespaceId"
          ]
        }
      }
    },
    "SecurityGroupRuleIngressHttp": {
      "Type": "ALIYUN::ECS::SecurityGroupIngress",
      "Properties": {
        "Description": {
          "Fn::Sub": "${ALIYUN::StackName}_allow_80"
        },
        "PortRange": "80/80",
        "SecurityGroupId": {
          "Ref": "SecurityGroup"
        },
        "Priority": 1,
        "SourceCidrIp": "0.0.0.0/0",
        "IpProtocol": "tcp"
      },
      "DependsOn": [
        "SecurityGroup"
      ]
    },
    "SaeApplication": {
      "Type": "ALIYUN::SAE::Application",
      "Properties": {
        "PackageUrl": "https://apple-application-bj.oss-cn-beijing.aliyuncs.com/releases/yudao-server.jar",
        "VpcId": {
          "Ref": "VPC"
        },
        "Jdk": "Open JDK 21",
        "Replicas": 1,
        "Envs": {
          "Fn::Sub": [
            "[{\"name\":\"JAVA_OPTS\",\"value\":\"-Dserver.port=8080\"},{\"name\":\"DB_PASSWORD\",\"valueFrom\":{\"secretRef\":{\"secretId\":${DB_PASSWORD_SECRET_ID},\"key\":\"DB_PASSWORD\"}}},{\"name\":\"REDIS_PASSWORD\",\"valueFrom\":{\"secretRef\":{\"secretId\":${REDIS_PASSWORD_SECRET_ID},\"key\":\"REDIS_PASSWORD\"}}}]",
            {
              "DB_PASSWORD_SECRET_ID": {
                "Fn::GetAtt": [
                  "SecretDB_PASSWORD",
                  "SecretId"
                ]
              },
              "REDIS_PASSWORD_SECRET_ID": {
                "Fn::GetAtt": [
                  "SecretREDIS_PASSWORD",
                  "SecretId"
                ]
              }
            }
          ]
        },
        "AppName": {
          "Ref": "AppName"
        },
        "NamespaceId": {
          "Fn::GetAtt": [
            "SaeNamespace",
            "NamespaceId"
          ]
        },
        "Deploy": true,
        "Readiness": {
          "Fn::Sub": "{\"httpGet\":{\"path\":\"${HealthCheckPath}\",\"port\":8080,\"scheme\":\"HTTP\"},\"initialDelaySeconds\":${HealthCheckInitialDelay},\"timeoutSeconds\":5}"
        },
        "PackageType": "FatJar",
        "VSwitchId": {
          "Ref": "VSwitch"
        },
        "Memory": 4096,
        "Timezone": "Asia/Shanghai",
        "SecurityGroupId": {
          "Ref": "SecurityGroup"
        },
        "Cpu": 2000
      },
      "DependsOn": [
        "SecretDB_PASSWORD",
        "SecretREDIS_PASSWORD"
      ]
    },
    "SecurityGroupRuleIngressHttps": {
      "Type": "ALIYUN::ECS::SecurityGroupIngress",
      "Properties": {
        "Description": {
          "Fn::Sub": "${ALIYUN::StackName}_allow_443"
        },
        "PortRange": "443/443",
        "SecurityGroupId": {
          "Ref": "SecurityGroup"
        },
        "Priority": 1,
        "SourceCidrIp": "0.0.0.0/0",
        "IpProtocol": "tcp"
      },
      "DependsOn": [
        "SecurityGroup"
      ]
    },
    "SecurityGroup": {
      "Type": "ALIYUN::ECS::SecurityGroup",
      "Properties": {
        "VpcId": {
          "Ref": "VPC"
        },
        "Description": "Security group for SAE instances",
        "SecurityGroupName": {
          "Fn::Sub": "${ALIYUN::StackName}_sg"
        }
      },
      "DependsOn": [
        "VPC"
      ]
    },
    "AlbServerGroup": {
      "Type": "ALIYUN::ALB::ServerGroup",
      "Properties": {
        "Protocol": "HTTP",
        "VpcId": {
          "Ref": "VPC"
        },
        "ServerGroupName": {
          "Fn::Sub": "${ALIYUN::StackName}_server_group"
        },
        "StickySessionConfig": {
          "StickySessionEnabled": false
        },
        "HealthCheckConfig": {
          "HealthCheckEnabled": true,
          "HealthCheckCodes": [
            "http_2xx"
          ],
          "HealthCheckPath": "/api/health",
          "HealthyThreshold": 3,
          "UnhealthyThreshold": 3,
          "HealthCheckTimeout": 5,
          "HealthCheckInterval": 2
        }
      }
    },
    "AlbListener": {
      "Type": "ALIYUN::ALB::Listener",
      "Properties": {
        "DefaultActions": [
          {
            "ForwardGroupConfig": {
              "ServerGroupTuples": [
                {
                  "ServerGroupId": {
                    "Ref": "AlbServerGroup"
                  }
                }
              ]
            },
            "Type": "ForwardGroup"
          }
        ],
        "ListenerProtocol": "HTTP",
        "ListenerPort": 80,
        "LoadBalancerId": {
          "Ref": "AlbInstance"
        }
      }
    },
    "AlbInstance": {
      "Type": "ALIYUN::ALB::LoadBalancer",
      "Properties": {
        "AddressType": "Internet",
        "ZoneMappings": [
          {
            "VSwitchId": {
              "Ref": "VSwitch"
            },
            "ZoneId": "us-east-1a"
          },
          {
            "VSwitchId": {
              "Ref": "VSwitchB"
            },
            "ZoneId": "us-east-1b"
          }
        ],
        "LoadBalancerEdition": "Basic",
        "LoadBalancerBillingConfig": {
          "PayType": "PostPay"
        },
        "VpcId": {
          "Ref": "VPC"
        },
        "AddressAllocatedMode": "Fixed",
        "LoadBalancerName": {
          "Fn::Sub": "${ALIYUN::StackName}_alb"
        }
      }
    },
    "VPC": {
      "Type": "ALIYUN::ECS::VPC",
      "Properties": {
        "VpcName": {
          "Fn::Sub": "${ALIYUN::StackName}_vpc"
        },
        "CidrBlock": "10.0.0.0/16",
        "Description": "VPC created by CDK for ALB + SAE + WAF architecture"
      }
    },
    "SecurityGroupRuleIngressApp": {
      "Type": "ALIYUN::ECS::SecurityGroupIngress",
      "Properties": {
        "Description": {
          "Fn::Sub": "${ALIYUN::StackName}_allow_8080"
        },
        "PortRange": "8080/8080",
        "SecurityGroupId": {
          "Ref": "SecurityGroup"
        },
        "Priority": 1,
        "SourceCidrIp": "0.0.0.0/0",
        "IpProtocol": "tcp"
      },
      "DependsOn": [
        "SecurityGroup"
      ]
    },
    "VSwitch": {
      "Type": "ALIYUN::ECS::VSwitch",
      "Properties": {
        "VSwitchName": {
          "Fn::Sub": "${ALIYUN::StackName}_vswitch"
        },
        "VpcId": {
          "Ref": "VPC"
        },
        "CidrBlock": "10.0.1.0/24",
        "Description": "VSwitch for SAE instances and ALB",
        "ZoneId": "us-east-1a"
      }
    },
    "VSwitchB": {
      "Type": "ALIYUN::ECS::VSwitch",
      "Properties": {
        "VSwitchName": {
          "Fn::Sub": "${ALIYUN::StackName}_b_vswitch"
        },
        "VpcId": {
          "Ref": "VPC"
        },
        "CidrBlock": "10.0.2.0/24",
        "Description": "VSwitch for SAE instances and ALB",
        "ZoneId": "us-east-1b"
      }
    },
    "ScalingRule": {
      "Type": "ALIYUN::SAE::ApplicationScalingRule",
      "Properties": {
        "ScalingRuleMetric": {
          "MinReplicas": 1,
          "Metrics": [
            {
              "MetricTargetAverageUtilization": 85,
              "MetricType": "CPU"
            }
          ],
          "ScaleUpRules": {
            "Disabled": false,
            "Step": "1",
            "StabilizationWindowSeconds": 60
          },
          "MaxReplicas": 9,
          "ScaleDownRules": {
            "Disabled": false,
            "Step": "1",
            "StabilizationWindowSeconds": 300
          }
        },
        "ScalingRuleName": {
          "Fn::Sub": "${AppName}-scaling-rule"
        },
        "ScalingRuleEnable": true,
        "ScalingRuleType": "metric",
        "AppId": {
          "Ref": "SaeApplication"
        },
        "MinReadyInstances": 0
      }
    },
    "DnsRecord": {
      "Type": "ALIYUN::DNS::DomainRecord",
      "Properties": {
        "TTL": 600,
        "Type": "CNAME",
        "Value": {
          "Fn::GetAtt": [
            "AlbInstance",
            "DNSName"
          ]
        },
        "RR": {
          "Ref": "DomainPrefix"
        },
        "DomainName": {
          "Ref": "RootDomain"
        }
      }
    }
  },
  "Description": "ALB + SAE (Single App with Versions) + WAF architecture deployment by CDK",
  "Parameters": {
    "PackageUrl": {
      "Default": "https://my-java-app-bucket.oss-us-east-1.aliyuncs.com/releases/hello-world-1.0-SNAPSHOT.jar",
      "Type": "String",
      "Description": "JAR Package OSS URL"
    },
    "CertificateId": {
      "Default": "24280745",
      "Type": "String",
      "Description": "ALB HTTPS 绑定用：填数字证书管理服务里证书列表的「证书ID」（多为纯数字）；勿填订阅实例 ID（cas_dv-cn-…）。若仍报找不到，再按文档尝试「证书ID-地域」全局格式。"
    },
    "AppName": {
      "Default": "apple-api-prod",
      "Type": "String",
      "Description": "SAE Application Name"
    },
    "HealthCheckPath": {
      "Default": "/api/health",
      "Type": "String",
      "Description": "Health Check Path"
    },
    "NamespaceId": {
      "Default": "us-east-1",
      "Type": "String",
      "Description": "SAE namespace logical ID only; stack region is prefixed automatically"
    },
    "HealthCheckInitialDelay": {
      "Default": 300,
      "Type": "Number",
      "Description": "健康检查初始延迟秒数（initialDelaySeconds），应用启动后等待这么久才开始健康检查。建议设为应用实际启动时间的 1.2~1.5 倍"
    },
    "DomainPrefix": {
      "Default": "api-prod",
      "Type": "String",
      "Description": "域名前缀，如 api-prod 将组成 api-prod.apple-app.cn"
    },
    "RootDomain": {
      "Default": "apple-app.cn",
      "Type": "String",
      "Description": "根域名，如 apple-app.cn"
    }
  },
  "Outputs": {
    "SaeNamespaceId": {
      "Description": "SAE Namespace ID (Region:LogicalId)",
      "Value": {
        "Fn::GetAtt": [
          "SaeNamespace",
          "NamespaceId"
        ]
      }
    },
    "AlbAddress": {
      "Description": "ALB public address",
      "Value": {
        "Fn::GetAtt": [
          "AlbInstance",
          "DNSName"
        ]
      }
    },
    "AlbId": {
      "Description": "ALB instance ID",
      "Value": {
        "Ref": "AlbInstance"
      }
    },
    "SaeApp": {
      "Description": "SAE Application Name",
      "Value": {
        "Ref": "SaeApplication"
      }
    },
    "VpcId": {
      "Description": "VPC ID",
      "Value": {
        "Ref": "VPC"
      }
    },
    "SaeIngressId": {
      "Description": "SAE Ingress ID",
      "Value": {
        "Ref": "SaeIngress"
      }
    }
  }
}