{
  "ROSTemplateFormatVersion": "2015-09-01",
  "Description": "VPC Peering connection between apple-api-esa-prod and apple-app-db",
  "Parameters": {
    "VpcIdProd": {
      "Type": "String",
      "Description": "VPC ID of apple-api-esa-prod stack (172.16.0.0/16)"
    },
    "VpcIdDb": {
      "Type": "String",
      "Description": "VPC ID of apple-app-db stack (192.168.0.0/16)"
    },
    "VpcCidrProd": {
      "Type": "String",
      "Description": "CIDR block of ESA prod VPC",
      "Default": "172.16.0.0/16"
    },
    "VpcCidrDb": {
      "Type": "String",
      "Description": "CIDR block of db VPC",
      "Default": "192.168.0.0/16"
    },
    "RouteTableIdProd": {
      "Type": "String",
      "Description": "Route table ID of ESA prod VPC"
    },
    "RouteTableIdDb": {
      "Type": "String",
      "Description": "Route table ID of db VPC"
    }
  },
  "Resources": {
    "VpcPeering": {
      "Type": "ALIYUN::VPC::VpcPeerConnection",
      "Properties": {
        "VpcId": {
          "Ref": "VpcIdProd"
        },
        "Description": "Peering between apple-api-esa-prod and apple-app-db",
        "Name": {
          "Fn::Sub": "${ALIYUN::StackName}_peering"
        },
        "AcceptingVpcId": {
          "Ref": "VpcIdDb"
        }
      }
    },
    "RouteEntryProdToDb": {
      "Type": "ALIYUN::ECS::Route",
      "Properties": {
        "RouteTableId": {
          "Ref": "RouteTableIdProd"
        },
        "DestinationCidrBlock": {
          "Ref": "VpcCidrDb"
        },
        "NextHopType": "VpcPeer",
        "NextHopId": {
          "Ref": "VpcPeering"
        }
      }
    },
    "RouteEntryDbToProd": {
      "Type": "ALIYUN::ECS::Route",
      "Properties": {
        "RouteTableId": {
          "Ref": "RouteTableIdDb"
        },
        "DestinationCidrBlock": {
          "Ref": "VpcCidrProd"
        },
        "NextHopType": "VpcPeer",
        "NextHopId": {
          "Ref": "VpcPeering"
        }
      }
    }
  },
  "Outputs": {
    "PeeringConnectionId": {
      "Description": "VPC Peering connection ID",
      "Value": {
        "Ref": "VpcPeering"
      }
    }
  }
}
