{
  "ROSTemplateFormatVersion": "2015-09-01",
  "Resources": {
    "DBInstance": {
      "Type": "ALIYUN::RDS::DBInstance",
      "Properties": {
        "DBInstanceStorage": 20,
        "SecurityIpList": [
          "192.168.1.0/24"
        ],
        "Engine": "MySQL",
        "EngineVersion": "8.0",
        "DBInstanceNetType": "Intranet",
        "PayType": "Prepaid",
        "Period": "Month",
        "UsedTime": 1,
        "DBInstanceClass": "rds.mysql.t1.small",
        "VSwitchId": {
          "Ref": "VSwitchId"
        },
        "VpcId": {
          "Ref": "VpcId"
        },
        "DBInstanceDescription": "apple-app-mysql",
        "SecurityGroupIds": [
          {
            "Ref": "SecurityGroupId"
          }
        ],
        "RetentionPolicy": "Keep",
        "Category": "Basic"
      }
    },
    "DBAccount": {
      "Type": "ALIYUN::RDS::Account",
      "Properties": {
        "DBInstanceId": {
          "Ref": "DBInstance"
        },
        "AccountName": "apple_admin",
        "AccountPassword": {
          "Ref": "DBPassword"
        },
        "AccountType": "Normal"
      },
      "DependsOn": [
        "DBInstance"
      ]
    },
    "RedisInstance": {
      "Type": "ALIYUN::REDIS::Instance",
      "Properties": {
        "SecurityIpList": [
          "192.168.1.0/24"
        ],
        "EngineVersion": "5.0",
        "PayType": "Prepaid",
        "Period": "Month",
        "UsedTime": 1,
        "InstanceClass": "redis.master.small.default",
        "VpcId": {
          "Ref": "VpcId"
        },
        "VSwitchId": {
          "Ref": "VSwitchId"
        },
        "InstanceDescription": "apple-app-redis",
        "SecurityGroupId": {
          "Ref": "SecurityGroupId"
        }
      }
    }
  },
  "Description": "Shared RDS MySQL + Redis architecture deployment by ROS",
  "Parameters": {
    "VpcId": {
      "Default": "vpc-uf6jkrhb0xxxxxxxx",
      "Type": "String",
      "Description": "Existing VPC ID for RDS and Redis"
    },
    "VSwitchId": {
      "Default": "vsw-uf65zqxxx0xxxxxxx",
      "Type": "String",
      "Description": "Existing VSwitch ID for RDS and Redis"
    },
    "SecurityGroupId": {
      "Default": "",
      "Type": "String",
      "Description": "Existing Security Group ID (leave empty to create new)"
    },
    "DBPassword": {
      "Default": "AppleDb2024!",
      "Type": "String",
      "NoEcho": true,
      "Description": "MySQL database password"
    }
  },
  "Outputs": {
    "VpcId": {
      "Description": "VPC ID",
      "Value": {
        "Ref": "VpcId"
      }
    },
    "VSwitchId": {
      "Description": "VSwitch ID",
      "Value": {
        "Ref": "VSwitchId"
      }
    },
    "SecurityGroupId": {
      "Description": "Security Group ID",
      "Value": {
        "Ref": "SecurityGroupId"
      }
    },
    "DBInstanceId": {
      "Description": "MySQL DBInstance ID",
      "Value": {
        "Ref": "DBInstance"
      }
    },
    "DBInstanceConnectionString": {
      "Description": "MySQL connection address (Intranet)",
      "Value": {
        "Fn::GetAtt": [
          "DBInstance",
          "ConnectionString"
        ]
      }
    },
    "RedisInstanceId": {
      "Description": "Redis instance ID",
      "Value": {
        "Ref": "RedisInstance"
      }
    },
    "RedisConnectionString": {
      "Description": "Redis connection address (Intranet)",
      "Value": {
        "Fn::GetAtt": [
          "RedisInstance",
          "ConnectionString"
        ]
      }
    }
  }
}
