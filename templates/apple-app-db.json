{
  "ROSTemplateFormatVersion": "2015-09-01",
  "Resources": {
    "Vpc": {
      "Type": "ALIYUN::ECS::VPC",
      "Properties": {
        "VpcName": "apple-app-db-vpc",
        "CidrBlock": "192.168.0.0/16",
        "Description": "VPC for shared RDS and Redis"
      }
    },
    "VSwitch": {
      "Type": "ALIYUN::ECS::VSwitch",
      "Properties": {
        "VSwitchName": "apple-app-db-vswitch",
        "VpcId": {
          "Ref": "Vpc"
        },
        "CidrBlock": "192.168.1.0/24",
        "Description": "VSwitch for RDS and Redis",
        "ZoneId": "us-east-1a"
      },
      "DependsOn": [
        "Vpc"
      ]
    },
    "SecurityGroup": {
      "Type": "ALIYUN::ECS::SecurityGroup",
      "Properties": {
        "VpcId": {
          "Ref": "Vpc"
        },
        "Description": "Security group for shared RDS and Redis",
        "SecurityGroupName": "apple-app-db-sg"
      },
      "DependsOn": [
        "Vpc"
      ]
    },
    "SecurityGroupRuleIngressMysql": {
      "Type": "ALIYUN::ECS::SecurityGroupIngress",
      "Properties": {
        "Description": "apple-app-db-allow-3306",
        "PortRange": "3306/3306",
        "SecurityGroupId": {
          "Ref": "SecurityGroup"
        },
        "Priority": 1,
        "SourceCidrIp": "192.168.1.0/24",
        "IpProtocol": "tcp"
      },
      "DependsOn": [
        "SecurityGroup"
      ]
    },
    "SecurityGroupRuleIngressRedis": {
      "Type": "ALIYUN::ECS::SecurityGroupIngress",
      "Properties": {
        "Description": "apple-app-db-allow-6379",
        "PortRange": "6379/6379",
        "SecurityGroupId": {
          "Ref": "SecurityGroup"
        },
        "Priority": 1,
        "SourceCidrIp": "192.168.1.0/24",
        "IpProtocol": "tcp"
      },
      "DependsOn": [
        "SecurityGroup"
      ]
    },
    "DBInstance": {
      "Type": "ALIYUN::RDS::PrepayDBInstance",
      "Properties": {
        "DBInstanceStorage": 20,
        "Engine": "MySQL",
        "EngineVersion": "8.0",
        "DBInstanceNetType": "Intranet",
        "Period": 1,
        "DBInstanceClass": "rds.mysql.t1.small",
        "VSwitchId": {
          "Ref": "VSwitch"
        },
        "VpcId": {
          "Ref": "Vpc"
        },
        "SecurityGroupId": {
          "Ref": "SecurityGroup"
        },
        "Category": "Basic"
      },
      "DependsOn": [
        "VSwitch"
      ]
    },
    "DBAccount": {
      "Type": "ALIYUN::RDS::Account",
      "Properties": {
        "DBInstanceId": {
          "Ref": "DBInstance"
        },
        "AccountName": "apple_admin",
        "AccountPassword": {
          "Ref": "DBPassword"
        },
        "AccountType": "Normal"
      },
      "DependsOn": [
        "DBInstance"
      ]
    },
    "RedisInstance": {
      "Type": "ALIYUN::REDIS::PrepayInstance",
      "Properties": {
        "EngineVersion": "5.0",
        "Period": 1,
        "ZoneId": {
          "Fn::GetAtt": [
            "VSwitch",
            "ZoneId"
          ]
        },
        "InstanceClass": "redis.master.small.default",
        "VpcId": {
          "Ref": "Vpc"
        },
        "VSwitchId": {
          "Ref": "VSwitch"
        },
        "SecurityGroupId": {
          "Ref": "SecurityGroup"
        }
      },
      "DependsOn": [
        "VSwitch"
      ]
    }
  },
  "Description": "Shared RDS MySQL + Redis architecture deployment by ROS",
  "Parameters": {
    "DBPassword": {
      "Default": "AppleDb2024!",
      "Type": "String",
      "NoEcho": true,
      "Description": "MySQL database password"
    }
  },
  "Outputs": {
    "VpcId": {
      "Description": "VPC ID",
      "Value": {
        "Ref": "Vpc"
      }
    },
    "VSwitchId": {
      "Description": "VSwitch ID",
      "Value": {
        "Ref": "VSwitch"
      }
    },
    "SecurityGroupId": {
      "Description": "Security Group ID",
      "Value": {
        "Ref": "SecurityGroup"
      }
    },
    "DBInstanceId": {
      "Description": "MySQL DBInstance ID",
      "Value": {
        "Ref": "DBInstance"
      }
    },
    "DBInstanceConnectionString": {
      "Description": "MySQL connection address (Intranet)",
      "Value": {
        "Fn::GetAtt": [
          "DBInstance",
          "InnerConnectionString"
        ]
      }
    },
    "RedisInstanceId": {
      "Description": "Redis instance ID",
      "Value": {
        "Ref": "RedisInstance"
      }
    },
    "RedisConnectionString": {
      "Description": "Redis connection address (Intranet)",
      "Value": {
        "Fn::GetAtt": [
          "RedisInstance",
          "ConnectionDomain"
        ]
      }
    }
  }
}
