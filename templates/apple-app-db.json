{
  "ROSTemplateFormatVersion": "2015-09-01",
  "Resources": {
    "Vpc": {
      "Type": "ALIYUN::ECS::VPC",
      "Properties": {
        "VpcName": "apple-app-db-vpc",
        "CidrBlock": "192.168.0.0/16",
        "Description": "VPC for shared RDS and Redis"
      }
    },
    "VSwitch": {
      "Type": "ALIYUN::ECS::VSwitch",
      "Properties": {
        "VSwitchName": "apple-app-db-vswitch",
        "VpcId": {
          "Ref": "Vpc"
        },
        "CidrBlock": "192.168.1.0/24",
        "Description": "VSwitch for RDS",
        "ZoneId": "us-east-1a"
      },
      "DependsOn": [
        "Vpc"
      ]
    },
    "VSwitchForRedis": {
      "Type": "ALIYUN::ECS::VSwitch",
      "Properties": {
        "VSwitchName": "apple-app-db-vswitch-redis",
        "VpcId": {
          "Ref": "Vpc"
        },
        "CidrBlock": "192.168.2.0/24",
        "Description": "VSwitch for Redis",
        "ZoneId": "us-east-1a"
      },
      "DependsOn": [
        "Vpc"
      ]
    },
    "SecurityGroup": {
      "Type": "ALIYUN::ECS::SecurityGroup",
      "Properties": {
        "VpcId": {
          "Ref": "Vpc"
        },
        "Description": "Security group for shared RDS and Redis",
        "SecurityGroupName": "apple-app-db-sg"
      },
      "DependsOn": [
        "Vpc"
      ]
    },
    "SecurityGroupRuleIngressMysql": {
      "Type": "ALIYUN::ECS::SecurityGroupIngress",
      "Properties": {
        "Description": "apple-app-db-allow-3306",
        "PortRange": "3306/3306",
        "SecurityGroupId": {
          "Ref": "SecurityGroup"
        },
        "Priority": 1,
        "SourceCidrIp": "192.168.1.0/24",
        "IpProtocol": "tcp"
      },
      "DependsOn": [
        "SecurityGroup"
      ]
    },
    "SecurityGroupRuleIngressRedis": {
      "Type": "ALIYUN::ECS::SecurityGroupIngress",
      "Properties": {
        "Description": "apple-app-db-allow-6379",
        "PortRange": "6379/6379",
        "SecurityGroupId": {
          "Ref": "SecurityGroup"
        },
        "Priority": 1,
        "SourceCidrIp": "192.168.1.0/24",
        "IpProtocol": "tcp"
      },
      "DependsOn": [
        "SecurityGroup"
      ]
    },
    "RedisInstance": {
      "Type": "ALIYUN::REDIS::PrepayInstance",
      "Properties": {
        "EngineVersion": "7.0",
        "Period": 1,
        "ZoneId": "us-east-1a",
        "InstanceClass": "redis.master.small.default",
        "VpcId": {
          "Ref": "Vpc"
        },
        "VSwitchId": {
          "Ref": "VSwitchForRedis"
        },
        "SecurityGroupId": {
          "Ref": "SecurityGroup"
        }
      },
      "DependsOn": [
        "VSwitchForRedis"
      ]
    }
  },
  "Description": "Shared RDS MySQL + Redis architecture deployment by ROS",
  "Outputs": {
    "VpcId": {
      "Description": "VPC ID",
      "Value": {
        "Ref": "Vpc"
      }
    },
    "VSwitchId": {
      "Description": "VSwitch ID",
      "Value": {
        "Ref": "VSwitch"
      }
    },
    "SecurityGroupId": {
      "Description": "Security Group ID",
      "Value": {
        "Ref": "SecurityGroup"
      }
    },
    "RedisInstanceId": {
      "Description": "Redis instance ID",
      "Value": {
        "Ref": "RedisInstance"
      }
    },
    "RedisConnectionString": {
      "Description": "Redis connection address (Intranet)",
      "Value": {
        "Fn::GetAtt": [
          "RedisInstance",
          "ConnectionDomain"
        ]
      }
    }
  }
}
