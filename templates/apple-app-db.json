{
  "ROSTemplateFormatVersion": "2015-09-01",
  "Parameters": {
    "Zone": {
      "Default": "us-east-1a",
      "AssociationProperty": "ALIYUN::ECS::Instance::ZoneId",
      "AssociationPropertyMetadata": {
        "WithAvailableResource": true,
        "DefaultValueStrategy": "first"
      },
      "Type": "String",
      "Label": {
        "zh-cn": "交换机可用区",
        "en": "VSwitch Availability Zone"
      }
    },
    "RDSDBInstanceDBInstanceClass": {
      "AssociationPropertyMetadata": {
        "Category": "${RDSDBInstanceCategory}",
        "Engine": "${RDSDBInstanceEngine}",
        "EngineVersion": "${RDSDBInstanceEngineVersion}",
        "ZoneId": "${RDSDBInstanceZoneId}",
        "InstanceChargeType": "${RDSDBInstancePayType}",
        "DBInstanceStorageType": "${RDSDBInstanceDBInstanceStorageType}"
      },
      "Description": {
        "en": "Database instance type. Refer the RDS database instance type reference, such as 'rds.mys2.large', 'rds.mss1.large', 'rds.pg.s1.small' etc"
      },
      "MinLength": 1,
      "Required": true,
      "Label": {
        "zh-cn": "实例规格",
        "en": "DBInstanceClass"
      },
      "MaxLength": 64,
      "AssociationProperty": "ALIYUN::RDS::Instance::InstanceType",
      "Type": "String"
    }
  },
  "Resources": {
    "VSwitch": {
      "Type": "ALIYUN::ECS::VSwitch",
      "Properties": {
        "VpcId": {
          "Ref": "VPC"
        },
        "CidrBlock": "10.0.0.0/24",
        "ZoneId": {
          "Ref": "Zone"
        }
      }
    },
    "SecurityGroup": {
      "Type": "ALIYUN::ECS::SecurityGroup",
      "Properties": {
        "SecurityGroupIngress": [
          {
            "Policy": "accept",
            "PortRange": "80/80",
            "Priority": 1,
            "SourceCidrIp": "0.0.0.0/0",
            "IpProtocol": "tcp"
          },
          {
            "Policy": "accept",
            "PortRange": "443/443",
            "Priority": 1,
            "SourceCidrIp": "0.0.0.0/0",
            "IpProtocol": "tcp"
          },
          {
            "Policy": "accept",
            "PortRange": "22/22",
            "Priority": 1,
            "SourceCidrIp": "0.0.0.0/0",
            "IpProtocol": "tcp"
          },
          {
            "Policy": "accept",
            "PortRange": "3389/3389",
            "Priority": 1,
            "SourceCidrIp": "0.0.0.0/0",
            "IpProtocol": "tcp"
          },
          {
            "Policy": "accept",
            "PortRange": "-1/-1",
            "Priority": 1,
            "SourceCidrIp": "0.0.0.0/0",
            "IpProtocol": "icmp"
          }
        ],
        "VpcId": {
          "Ref": "VPC"
        }
      }
    },
    "REDISInstance": {
      "Type": "ALIYUN::REDIS::Instance",
      "Properties": {
        "VpcId": {
          "Ref": "VPC"
        },
        "ChargeType": "PrePaid",
        "AutoRenewDuration": 1,
        "Period": 1,
        "ZoneId": {
          "Ref": "Zone"
        },
        "InstanceClass": "redis.shard.small.y.ee",
        "PeriodUnit": "Month",
        "VSwitchId": {
          "Ref": "VSwitch"
        },
        "DeletionForce": false,
        "EngineVersion": "7.0",
        "ProductType": "OnECS",
        "SubscriptionDeletionForce": false
      }
    },
    "VPC": {
      "Type": "ALIYUN::ECS::VPC",
      "Properties": {
        "CidrBlock": "10.0.0.0/8",
        "EnableIpv6": false
      }
    },
    "RDSDBInstance": {
      "Type": "ALIYUN::RDS::DBInstance",
      "Properties": {
        "StorageAutoScale": "Disable",
        "Engine": "MySQL",
        "VpcId": {
          "Ref": "VPC"
        },
        "ConnectionStringType": "Inner",
        "PeriodType": "Month",
        "SubscriptionDeletionForce": false,
        "SecurityGroupId": {
          "Ref": "SecurityGroup"
        },
        "SSLSetting": "Disabled",
        "PayType": "PrePaid",
        "Category": "Basic",
        "Period": 1,
        "DBInstanceNetType": "Internet",
        "EngineVersion": "8.0",
        "DBInstanceStorage": 20,
        "VSwitchId": {
          "Ref": "VSwitch"
        },
        "MasterUserType": "Normal",
        "DBInstanceStorageType": "cloud_ssd",
        "DBInstanceClass": "mysql.n1e.small.1",
        "SecurityIPList": "0.0.0.0/0",
        "InstanceNetworkType": "VPC",
        "ZoneId": "us-east-1a"
      }
    }
  },
